import numpy as np
def calculate_covariance_matrix(vectors: list[list[float]]) -> list[list[float]]:
	# Your code here

	def covariance(x: list[float], y: list[float])-> float:
		cov = 0
		for k in range(len(x)):
			cov +=( (x[k]-np.mean(x))*(y[k]-np.mean(y)))/(len(x)-1)
		return  cov

	cov_matrix = [[0.0 for _ in range(len(vectors))] for _ in range(len(vectors))]

	for i in range(len(vectors)):
		for j in range(len(vectors)):
			cov_matrix[i][j] = covariance(vectors[i], vectors[j])
	return cov_matrix
