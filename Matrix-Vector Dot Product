def matrix_dot_vector(a: list[list[int|float]], b: list[int|float]) -> list[int|float]:

  if len(a[0]) == len (b):
    dot_product = []

    for row in range(0, len(a)):
      row_dot_product = 0
      for col in range(0, len(a[0])):
        row_dot_product+= a[row][col]*b[col] 
        # return row_dot_product
      dot_product.append(row_dot_product)
    return dot_product
  else:
    return -1
matrix_dot_vector([[1, 2, 3], [2, 4, 5], [6, 8, 9]], [1, 2, 3])
