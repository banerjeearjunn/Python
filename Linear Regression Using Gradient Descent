import numpy as np

def linear_regression_gradient_descent(X: np.ndarray, y: np.ndarray, alpha: float, iterations: int) -> np.ndarray:

    X = np.array(X)
    y = np.array(y)

    m, n = X.shape
    y = y.reshape(-1, 1)
    theta = np.zeros((n, 1)) 

    for k in range(iterations):
        y_cap = X.dot(theta)
        e = y_cap - y
        g = 1/len(X)*X.T.dot(e)
        theta = theta - alpha*(1/len(X))*X.T.dot(e)
    return np.round(theta.flatten(), 4)
